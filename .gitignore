# ── Ambiente virtuale Python ────────────────────────────────────────────────
.venv/
venv/
env/

# ── Cache Python ─────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd

# ── llama.cpp — repo clonato (si riclona dal llama Studio) ──────────────────
llama_cpp_studio/llama.cpp/
C_software/llama.cpp/

# ── C_software — binari e oggetti compilati ───────────────────────────────────
C_software/*.o
C_software/prismalux
C_software/prismalux_http
C_software/vram_bench
C_software/download_model
C_software.zip

# ── Modelli GGUF personali (troppo grandi per git) ───────────────────────────
llama_cpp_studio/models/*.gguf
*.gguf

# ── Output Multi-Agente (generati a runtime, tutti in esportazioni/) ─────────
esportazioni/
multi_agente/output_*.py
multi_agente/report_*.html

# ── Cython build artifacts ────────────────────────────────────────────────────
*.so
*.pyd
*.c
*.html
build/
dist/
*.egg-info/
setup_cython.py

# ── File di sistema ───────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Log e file temporanei ─────────────────────────────────────────────────────
*.log
*.tmp
*.bak

# ── Memoria Claude (sessione locale, non versionare) ─────────────────────────
.claude/

# ── Memoria persistente agenti ────────────────────────────────────────────────
~/.multi_agente_memoria.json
~/.multi_agente_llm_db.json

# ── Dati utente sensibili ─────────────────────────────────────────────────────
strumento_pratico/cv/*.pdf
strumento_pratico/cv/*.txt
