<?xml version="1.0" encoding="utf-8"?>
<!--
  Consente HTTP cleartext per connessioni LAN (Prismalux Desktop).
  La restrizione "solo LAN" è garantita a livello applicativo:
  l'unico endpoint configurabile è l'IP inserito dall'utente in Impostazioni.
  Nessun endpoint internet è hardcodato nell'app.

  Nota tecnica: Android non supporta range CIDR nei tag <domain>.
  La policy "cleartext solo LAN" è applicata dall'app, non dal manifest.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>
</network-security-config>
