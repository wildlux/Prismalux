<?xml version="1.0" encoding="utf-8"?>
<!-- AndroidManifest.xml — PrismaluxMobile
     Richiede Android 8.0+ (API 26) per BLE + Camera2 API.
     Tutti i permessi pericolosi (CAMERA, BT_CONNECT, BT_SCAN)
     devono essere richiesti a runtime tramite QCoreApplication::requestPermission(). -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="org.prismalux.mobile"
    android:versionCode="1"
    android:versionName="1.0">

    <!-- ── SDK range ─────────────────────────────────────────── -->
    <uses-sdk
        android:minSdkVersion="26"
        android:targetSdkVersion="34" />

    <!-- ── Rete LAN (Ollama) ─────────────────────────────────── -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- Traffico HTTP in chiaro verso indirizzi LAN (es. 192.168.x.x) -->
    <!-- Vedi anche: res/xml/network_security_config.xml            -->

    <!-- ── Camera ────────────────────────────────────────────── -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera"         android:required="false" />
    <uses-feature android:name="android.hardware.camera.autofocus" android:required="false" />

    <!-- ── Bluetooth LE (API 31+: permessi granulari) ────────── -->
    <!-- API 26-30: permessi legacy -->
    <uses-permission
        android:name="android.permission.BLUETOOTH"
        android:maxSdkVersion="30" />
    <uses-permission
        android:name="android.permission.BLUETOOTH_ADMIN"
        android:maxSdkVersion="30" />
    <!-- Per la geolocalizzazione richiesta da BLE scan su API < 31 -->
    <uses-permission
        android:name="android.permission.ACCESS_FINE_LOCATION"
        android:maxSdkVersion="30" />
    <!-- API 31+: permessi granulari obbligatori -->
    <uses-permission
        android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <uses-feature android:name="android.hardware.bluetooth_le" android:required="false" />

    <!-- ── Storage (per caricare documenti RAG) ──────────────── -->
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <!-- API 33+: permesso granulare per documenti -->
    <uses-permission
        android:name="android.permission.READ_MEDIA_DOCUMENTS"
        android:minSdkVersion="33" />

    <!-- ── Vibrazione (feedback tattile) ─────────────────────── -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- ── Applicazione ──────────────────────────────────────── -->
    <application
        android:label="PrismaluxMobile"
        android:theme="@style/AppTheme"
        android:hardwareAccelerated="true"
        android:usesCleartextTraffic="true"
        android:networkSecurityConfig="@xml/network_security_config"
        android:requestLegacyExternalStorage="false">

        <!-- Activity principale generata da Qt -->
        <activity
            android:name="org.qtproject.qt.android.bindings.QtActivity"
            android:configChanges="orientation|uiMode|screenLayout|screenSize|smallestScreenSize|layoutDirection|locale|fontScale|keyboard|keyboardHidden|navigation|mcc|mnc|density"
            android:launchMode="singleTop"
            android:screenOrientation="portrait"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Metadati Qt richiesti dal binding -->
            <meta-data android:name="android.app.lib_name"        android:value="PrismaluxMobile" />
            <meta-data android:name="android.app.qt_theme_type"   android:value="4" />
        </activity>
    </application>
</manifest>
