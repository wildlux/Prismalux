/* ══════════════════════════════════════════════════════════════
   Prismalux GUI — Tema ChatGPT / Claude Desktop
   ══════════════════════════════════════════════════════════════
   Palette:
     bg-main    #1a1a1a  — sfondo principale (quasi nero)
     bg-sidebar #111111  — sidebar più scura
     bg-surface #262626  — card, input, dialog
     bg-hover   #2f2f2f  — hover elements
     bg-input   #303030  — campo testo input
     border     #383838  — bordi sottili
     accent     #0ea5e9  — sky blue — azioni primarie
     green      #10a37f  — server attivo, completato
     yellow     #eab308  — avviso
     red        #ef4444  — errore, stop
     text       #e5e7eb  — testo principale
     text-muted #6b7280  — testo secondario

   Tipografia:
     UI:   Inter / Segoe UI / Ubuntu / DejaVu Sans
     Mono: JetBrains Mono / Fira Code — SOLO chat/log
   ══════════════════════════════════════════════════════════════ */

/* ── Reset globale ──────────────────────────────────────────── */
* {
    /* Windows-first fallback: Segoe UI è built-in su Win10/11.
       Ubuntu e DejaVu Sans coprono Linux. Arial è l'ultima spiaggia. */
    font-family: "Inter", "Segoe UI", "Segoe UI Variable", "Ubuntu",
                 "DejaVu Sans", "Helvetica Neue", "Arial", sans-serif;
    font-size: 13px;
    font-style: normal;
    color: #e5e7eb;
    outline: none;
}

QMainWindow, QWidget {
    background-color: #1a1a1a;
}

QScrollArea {
    background-color: transparent;
    border: none;
}

/* ── Scrollbar sottile stile VS Code ────────────────────────── */
QScrollBar:vertical {
    background: transparent;
    width: 6px;
    margin: 0;
}
QScrollBar::handle:vertical {
    background: #404040;
    min-height: 30px;
    border-radius: 3px;
}
QScrollBar::handle:vertical:hover { background: #555555; }
QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical { height: 0; }
QScrollBar::add-page:vertical,
QScrollBar::sub-page:vertical { background: transparent; }

QScrollBar:horizontal {
    background: transparent;
    height: 6px;
    margin: 0;
}
QScrollBar::handle:horizontal {
    background: #404040;
    min-width: 30px;
    border-radius: 3px;
}
QScrollBar::handle:horizontal:hover { background: #555555; }
QScrollBar::add-line:horizontal,
QScrollBar::sub-line:horizontal { width: 0; }

/* ── Header minimale ────────────────────────────────────────── */
#header {
    background-color: #111111;
    border-bottom: 1px solid #2a2a2a;
}

#headerTitle {
    font-size: 14px;
    font-weight: 600;
    color: #e5e7eb;
    letter-spacing: 2px;
}

#headerSub {
    font-size: 11px;
    color: #6b7280;
}

#headerBeer {
    font-size: 20px;
}

/* ── Sidebar stile ChatGPT ──────────────────────────────────── */
#sidebar {
    background-color: #111111;
    border-right: 1px solid #2a2a2a;
    min-width: 240px;
    max-width: 240px;
}

/* ── Bottoni navigazione — stile Claude/ChatGPT ─────────────── */
QPushButton#navBtn {
    background-color: transparent;
    border: none;
    border-radius: 6px;
    color: #9ca3af;
    text-align: left;
    padding: 6px 10px;   /* era 0 — causava troncatura su Windows */
    font-size: 13px;
    font-weight: 500;
    margin: 1px 6px;
}

QPushButton#navBtn:hover {
    background-color: #1f1f1f;
    color: #e5e7eb;
}

QPushButton#navBtn[active="true"] {
    background-color: #262626;
    color: #e5e7eb;
    border-left: 2px solid #0ea5e9;
    margin-left: 6px;
}

/* ── Separatore sidebar ─────────────────────────────────────── */
#sidebarSep {
    background-color: #2a2a2a;
    max-height: 1px;
    min-height: 1px;
    margin: 4px 8px;
    border: none;
}

/* ── Pulsante Nuova Chat ────────────────────────────────────── */
QPushButton#newChatBtn {
    background-color: transparent;
    border: 1px solid #383838;
    border-radius: 6px;
    color: #9ca3af;
    text-align: left;
    padding: 6px 12px;
    font-size: 12px;
    margin: 4px 8px;
}

QPushButton#newChatBtn:hover {
    background-color: #1f1f1f;
    border-color: #4a4a4a;
    color: #e5e7eb;
}

/* ── Lista chat history ─────────────────────────────────────── */
QListWidget#chatList {
    background-color: transparent;
    border: none;
    padding: 0 4px;
    color: #9ca3af;
    font-size: 12px;
}

QListWidget#chatList::item {
    padding: 6px 8px;
    border-radius: 6px;
    margin: 1px 4px;
    border: none;
}

QListWidget#chatList::item:hover {
    background-color: #1f1f1f;
    color: #e5e7eb;
}

QListWidget#chatList::item:selected {
    background-color: #262626;
    color: #e5e7eb;
}

/* ── Area contenuto ─────────────────────────────────────────── */
#contentArea {
    background-color: #1a1a1a;
}

/* ── Card azione ────────────────────────────────────────────── */
QFrame#actionCard {
    background-color: #262626;
    border: 1px solid #383838;
    border-radius: 8px;
    padding: 4px;
}

QFrame#actionCard:hover {
    background-color: #2f2f2f;
    border-color: #4a4a4a;
}

QPushButton#cardBtn {
    background-color: transparent;
    border: none;
    text-align: left;
    padding: 14px 18px;
    color: #d1d5db;
    font-size: 13px;
}

QPushButton#cardBtn:hover { color: #ffffff; }
QPushButton#cardBtn:pressed { color: #0ea5e9; }

#cardIcon {
    font-size: 20px;
    padding: 0 6px;
    color: #9ca3af;
}

#cardTitle {
    font-size: 13px;
    font-weight: 600;
    color: #e5e7eb;
}

#cardDesc {
    font-size: 11px;
    color: #6b7280;
}

/* ── Gauge hardware ─────────────────────────────────────────── */
#gaugeLabel {
    font-size: 10px;
    font-weight: 600;
    color: #6b7280;
    min-width: 30px;
}

#gaugePct {
    font-size: 10px;
    color: #9ca3af;
    min-width: 38px;
    text-align: right;
}

QProgressBar#resBar {
    background-color: #2f2f2f;
    border: none;
    border-radius: 3px;
    max-height: 5px;
}

QProgressBar#resBar::chunk {
    border-radius: 3px;
    background-color: #10a37f;
}

QProgressBar#resBar[level="warn"]::chunk { background-color: #eab308; }
QProgressBar#resBar[level="crit"]::chunk { background-color: #ef4444; }

/* ── Chat log — monospace solo qui ─────────────────────────── */
QTextEdit#chatLog {
    font-family: "JetBrains Mono", "Fira Code", "Consolas", "Courier New", monospace;
    font-size: 13px;
    line-height: 1.6;
    background-color: #1a1a1a;
    border: none;
    border-radius: 0;
    color: #d1d5db;
    padding: 16px 20px;
    selection-background-color: #0ea5e9;
    selection-color: #000000;
}

/* ── Input chat — pill shape ────────────────────────────────── */
QLineEdit#chatInput {
    background-color: #2f2f2f;
    border: 1px solid #404040;
    border-radius: 20px;
    color: #e5e7eb;
    padding: 9px 18px;
    font-size: 13px;
    selection-background-color: #0ea5e9;
}

QLineEdit#chatInput:focus {
    border-color: #0ea5e9;
    background-color: #333333;
}

QLineEdit#chatInput:hover { border-color: #4a4a4a; }

/* ── Input multi-riga (StrumentiPage, TextEdit) ─────────────── */
QTextEdit#chatInput {
    background-color: #2f2f2f;
    border: 1px solid #404040;
    border-radius: 6px;
    color: #e5e7eb;
    padding: 8px 12px;
    font-size: 13px;
    selection-background-color: #0ea5e9;
    selection-color: #000000;
}

QTextEdit#chatInput:focus { border-color: #0ea5e9; background-color: #333333; }
QTextEdit#chatInput:hover { border-color: #4a4a4a; }

/* ── Bottoni azione primari ─────────────────────────────────── */
QPushButton#actionBtn {
    background-color: #0ea5e9;
    border: none;
    border-radius: 6px;
    color: #ffffff;
    font-weight: 600;
    font-size: 12px;
    padding: 7px 14px;
    min-width: 60px;     /* evita troncatura testo su Windows/HiDPI */
}

QPushButton#actionBtn:hover  { background-color: #38bdf8; }
QPushButton#actionBtn:pressed { background-color: #0284c7; }

QPushButton#actionBtn[danger="true"] {
    background-color: #ef4444;
    color: #ffffff;
}

QPushButton#actionBtn[danger="true"]:hover { background-color: #f87171; }

/* ── Pulsante simbolo (pannello inline Ω Simboli) ───────────── */
QPushButton#symbolBtn {
    background-color: #2a2a2a;
    border: 1px solid #404040;
    border-radius: 4px;
    color: #d1d5db;
    font-size: 11px;
    font-style: normal;
    font-family: "Inter", "Segoe UI", "DejaVu Sans", "Noto Sans", sans-serif;
    padding: 0px;
}
QPushButton#symbolBtn:hover  { background-color: #1e3a5f; color: #38bdf8; border-color: #0ea5e9; }
QPushButton#symbolBtn:pressed { background-color: #0ea5e9; color: #ffffff; }

/* ── Pulsante toggle backend ────────────────────────────────── */
QPushButton#backendBtn {
    background-color: #262626;
    color: #9ca3af;
    border: 1px solid #383838;
    border-radius: 6px;
    padding: 4px 12px;
    font-weight: 500;
    font-size: 12px;
}

QPushButton#backendBtn:hover {
    background-color: #2f2f2f;
    color: #e5e7eb;
    border-color: #4a4a4a;
}

QPushButton#backendBtn[backendActive="llama"] { color: #10a37f; border-color: rgba(16,163,127,0.4); }
QPushButton#backendBtn[backendActive="llama"]:hover { background-color: #10a37f; color: #000; border-color: #10a37f; }

/* ── Pulsante avvia/ferma server ────────────────────────────── */
QPushButton#serverBtn {
    background-color: #262626;
    color: #10a37f;
    border: 1px solid rgba(16,163,127,0.3);
    border-radius: 6px;
    padding: 4px 12px;
    font-weight: 500;
    font-size: 12px;
}

QPushButton#serverBtn:hover { background-color: #10a37f; color: #000; border-color: #10a37f; }

QPushButton#serverBtn[serverActive="true"] { color: #ef4444; border-color: rgba(239,68,68,0.3); }
QPushButton#serverBtn[serverActive="true"]:hover { background-color: #ef4444; color: #fff; border-color: #ef4444; }

/* ── Spinner ────────────────────────────────────────────────── */
QLabel#spinnerLabel {
    color: #eab308;
    font-size: 13px;
    padding: 0 4px;
}

/* ── Pulsante "Scarica LLM" (unloadBtn) ────────────────────── */
QPushButton#unloadBtn {
    background-color: transparent;
    border: 1px solid rgba(234,179,8,0.4);
    border-radius: 6px;
    font-size: 12px;
    font-weight: 600;
    color: #a16207;
    padding: 4px 10px;
}
QPushButton#unloadBtn:hover {
    background-color: #eab308;
    border-color: #eab308;
    color: #1e1e1e;
}
/* Stati urgenza: sovrascrivono il colore base */
QPushButton#unloadBtn[urgency="warn"] {
    border-color: #eab308;
    color: #854d0e;
    background-color: rgba(234,179,8,0.12);
}
QPushButton#unloadBtn[urgency="high"] {
    border-color: #ef4444;
    color: #b91c1c;
    background-color: rgba(239,68,68,0.12);
}

/* ── Pulsante emergenza RAM ─────────────────────────────────── */
QPushButton#emergencyBtn {
    background-color: transparent;
    border: 1px solid rgba(239,68,68,0.3);
    border-radius: 6px;
    font-size: 15px;
    color: #f87171;
}

QPushButton#emergencyBtn:hover {
    background-color: #ef4444;
    border-color: #ef4444;
    color: #ffffff;
}

/* ── Pulsante ⚙️ impostazioni ────────────────────────────────── */
QPushButton#themeBtn {
    background-color: transparent;
    border: 1px solid #383838;
    border-radius: 6px;
    font-size: 15px;
    color: #6b7280;
}

QPushButton#themeBtn:hover {
    background-color: #262626;
    color: #e5e7eb;
    border-color: #4a4a4a;
}

/* ── Barra progresso pipeline nella status bar ──────────────── */
QProgressBar#statusProgress {
    background-color: #2f2f2f;
    border: none;
    border-radius: 3px;
    color: #9ca3af;
    font-size: 11px;
    text-align: center;
}

QProgressBar#statusProgress::chunk {
    background-color: #0ea5e9;
    border-radius: 3px;
}

/* ── Status bar ─────────────────────────────────────────────── */
QStatusBar {
    background-color: #111111;
    border-top: 1px solid #2a2a2a;
    color: #6b7280;
    /* Segoe UI Emoji (Win) e Noto Color Emoji (Linux) garantiscono
       la resa corretta delle emoji anche nella barra di stato */
    font-family: "Inter", "Segoe UI", "Segoe UI Emoji",
                 "Noto Color Emoji", "Apple Color Emoji",
                 "Ubuntu", "DejaVu Sans", sans-serif;
    font-size: 12px;
    padding: 2px 10px;
}

/* ── Titoli pagina ──────────────────────────────────────────── */
#pageTitle {
    font-size: 18px;
    font-weight: 700;
    color: #e5e7eb;
    padding-bottom: 2px;
}

#pageSubtitle {
    font-size: 12px;
    color: #6b7280;
}

#pageDivider {
    background-color: #2a2a2a;
    max-height: 1px;
    min-height: 1px;
}

/* ── ComboBox ───────────────────────────────────────────────── */
QComboBox {
    background-color: #262626;
    border: 1px solid #383838;
    border-radius: 6px;
    padding: 5px 10px;
    color: #d1d5db;
    selection-background-color: #2f2f2f;
}

QComboBox:hover  { border-color: #4a4a4a; }
QComboBox:focus  { border-color: #0ea5e9; }

QComboBox::drop-down {
    border: none;
    width: 20px;
}

QComboBox QAbstractItemView {
    background-color: #262626;
    border: 1px solid #383838;
    selection-background-color: #2f2f2f;
    selection-color: #e5e7eb;
    color: #d1d5db;
    outline: none;
}

/* ── QGroupBox ──────────────────────────────────────────────── */
QGroupBox {
    border: 1px solid #383838;
    border-radius: 6px;
    margin-top: 1em;
    padding-top: 8px;
    font-weight: 600;
    color: #9ca3af;
}

QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    padding: 0 6px;
    color: #d1d5db;
}

/* ── QDialog ────────────────────────────────────────────────── */
QDialog {
    background-color: #1a1a1a;
}

/* ── QLabel generico ────────────────────────────────────────── */
QLabel {
    background-color: transparent;
}

/* ── QLineEdit generico ─────────────────────────────────────── */
QLineEdit {
    background-color: #262626;
    border: 1px solid #383838;
    border-radius: 6px;
    color: #e5e7eb;
    padding: 6px 10px;
    selection-background-color: #0ea5e9;
}

QLineEdit:focus { border-color: #0ea5e9; }
QLineEdit:hover { border-color: #4a4a4a; }

/* ── QSpinBox ───────────────────────────────────────────────── */
QSpinBox {
    background-color: #262626;
    border: 1px solid #383838;
    border-radius: 6px;
    padding: 4px 8px;
    color: #d1d5db;
}

QSpinBox:focus { border-color: #0ea5e9; }

QSpinBox::up-button, QSpinBox::down-button {
    background-color: #303030;
    border: none;
    width: 16px;
}

QSpinBox::up-button:hover, QSpinBox::down-button:hover {
    background-color: #0ea5e9;
}

/* ── QCheckBox ──────────────────────────────────────────────── */
QCheckBox {
    spacing: 8px;
    color: #d1d5db;
}

QCheckBox::indicator {
    width: 15px;
    height: 15px;
    border: 1px solid #4a4a4a;
    border-radius: 4px;
    background-color: #262626;
}

QCheckBox::indicator:checked {
    background-color: #0ea5e9;
    border-color: #0ea5e9;
}

QCheckBox::indicator:hover { border-color: #0ea5e9; }

/* ── QRadioButton ───────────────────────────────────────────── */
QRadioButton {
    spacing: 8px;
    color: #d1d5db;
}

QRadioButton::indicator {
    width: 14px;
    height: 14px;
    border: 1px solid #4a4a4a;
    border-radius: 7px;
    background-color: #262626;
}

QRadioButton::indicator:checked {
    background-color: #0ea5e9;
    border-color: #0ea5e9;
}

/* ── QDialogButtonBox ───────────────────────────────────────── */
QDialogButtonBox QPushButton {
    background-color: #262626;
    border: 1px solid #383838;
    border-radius: 6px;
    padding: 6px 18px;
    color: #d1d5db;
    min-width: 80px;
}

QDialogButtonBox QPushButton:hover {
    background-color: #2f2f2f;
    border-color: #0ea5e9;
    color: #ffffff;
}

QDialogButtonBox QPushButton:default {
    background-color: #0ea5e9;
    color: #ffffff;
    border-color: #0ea5e9;
    font-weight: 600;
}

QDialogButtonBox QPushButton:default:hover { background-color: #38bdf8; }

/* ── QMessageBox ────────────────────────────────────────────── */
QMessageBox { background-color: #1a1a1a; }
QMessageBox QLabel { color: #e5e7eb; }

/* ── QMenu ──────────────────────────────────────────────────── */
QMenu {
    background-color: #262626;
    border: 1px solid #383838;
    border-radius: 6px;
    padding: 4px 0;
    color: #d1d5db;
}

QMenu::item { padding: 7px 20px; }

QMenu::item:selected {
    background-color: #2f2f2f;
    color: #e5e7eb;
}

QMenu::separator {
    height: 1px;
    background: #383838;
    margin: 4px 10px;
}

/* ── QToolTip ───────────────────────────────────────────────── */
QToolTip {
    background-color: #262626;
    border: 1px solid #383838;
    border-radius: 4px;
    color: #e5e7eb;
    padding: 5px 10px;
    font-size: 12px;
}

/* ── RAG drop widget ────────────────────────────────────────── */
QFrame#ragDrop {
    background-color: #262626;
    border: 1px dashed #404040;
    border-radius: 6px;
}

QFrame#ragDrop:hover {
    border-color: #0ea5e9;
    background-color: #2a2a2a;
}

/* ── QTabWidget principale (Agenti | Finanza | Impara) ─────── */
QTabWidget#mainTabs {
    background-color: #141414;
}

QTabWidget#mainTabs::pane {
    border: none;
    background-color: #141414;
}

QTabWidget#mainTabs::tab-bar {
    alignment: left;
}

QTabBar#mainTabs--QTabBar::tab,
QTabWidget#mainTabs > QTabBar::tab {
    background-color: transparent;
    border: none;
    border-bottom: 2px solid transparent;
    padding: 10px 18px;  /* ridotto da 22px: più tab visibili su Windows */
    color: #6b7280;
    font-size: 13px;
    font-weight: 600;
    min-width: 80px;     /* garantisce che l'emoji + testo non si tronchi */
}

QTabWidget#mainTabs > QTabBar::tab:hover {
    color: #e5e7eb;
    background-color: #1c1c1c;
}

QTabWidget#mainTabs > QTabBar::tab:selected {
    color: #e5e7eb;
    border-bottom: 2px solid #0ea5e9;
}

/* ── QTabWidget Impostazioni ────────────────────────────────── */
QTabWidget#settingsTabs {
    background-color: #1a1a1a;
}

QTabWidget#settingsTabs::pane {
    border: none;
    border-top: 1px solid #2a2a2a;
    background-color: #1a1a1a;
}

QTabWidget#settingsTabs::tab-bar {
    alignment: left;
}

QTabBar::tab {
    background-color: transparent;
    border: none;
    border-bottom: 2px solid transparent;
    padding: 10px 20px;
    color: #6b7280;
    font-size: 13px;
    font-weight: 500;
}

QTabBar::tab:hover {
    color: #e5e7eb;
    background-color: #1f1f1f;
}

QTabBar::tab:selected {
    color: #e5e7eb;
    border-bottom: 2px solid #0ea5e9;
}

/* ── Breadcrumb indice sezione nell'header ──────────────────── */
#headerPage {
    font-size: 13px;
    font-weight: 600;
    color: #e5e7eb;
    padding: 0 4px;
}

#headerVSep {
    color: #2a2a2a;
    max-width: 1px;
    min-width: 1px;
    margin: 8px 4px;
}

/* ════════════════════════════════════════════════════════════
   Chat Bubble — stili per OracoloPage
   ════════════════════════════════════════════════════════════ */

/* Riga contenitore (trasparente) */
#chatBubbleRow {
    background: transparent;
    border: none;
}

/* Scroll area chat */
#chatScroll {
    background-color: #1a1a1a;
    border: none;
}
#chatContainer {
    background-color: transparent;
}

/* ── Bubble AI (sinistra — tema Prismalux cyan) ───────────── */
QFrame#bubbleAI {
    background-color: #0a1628;
    border: 1px solid rgba(14, 165, 233, 0.28);
    border-radius: 14px;
    border-top-left-radius: 3px;
}

/* ── Bubble Utente (destra — cyan gradient) ───────────────── */
QFrame#bubbleUser {
    background-color: #0e3248;
    border: 1px solid rgba(14, 165, 233, 0.45);
    border-radius: 14px;
    border-top-right-radius: 3px;
}

/* ── Sender label AI ──────────────────────────────────────── */
#bubbleSenderAI {
    font-size: 11px;
    font-weight: 600;
    color: #38bdf8;
}

/* ── Sender label Utente ──────────────────────────────────── */
#bubbleSenderUser {
    font-size: 11px;
    font-weight: 600;
    color: #7dd3fc;
}

/* ── Testo bubble (QTextBrowser) ──────────────────────────── */
QTextBrowser#bubbleText {
    background: transparent;
    border: none;
    color: #e2e8f0;
    font-size: 13px;
    line-height: 1.55;
    selection-background-color: #0ea5e9;
    selection-color: #000000;
}

/* ── Pulsanti azione bubble (Copia / Leggi / Grafico) ─────── */
QPushButton#bubbleBtn {
    background-color: #0f1f35;
    border: 1px solid rgba(14, 165, 233, 0.25);
    border-radius: 5px;
    color: #64748b;
    font-size: 11px;
    padding: 3px 10px;
    min-width: 0;
}

QPushButton#bubbleBtn:hover {
    background-color: #1a3a5c;
    border-color: #0ea5e9;
    color: #e2e8f0;
}

QPushButton#bubbleBtn:pressed {
    background-color: #0ea5e9;
    color: #000000;
}

/* ── Quick bar (pillole azione rapida) ────────────────────── */
#quickBar {
    background-color: #0d1117;
    border-top: 1px solid rgba(14, 165, 233, 0.15);
}

QScrollArea#quickBarScroll {
    background: transparent;
    border: none;
}

QPushButton#quickPill {
    background-color: #0f1f35;
    border: 1px solid rgba(14, 165, 233, 0.30);
    border-radius: 14px;
    color: #64748b;
    font-size: 11px;
    padding: 5px 14px;
    min-width: 0;
    white-space: nowrap;
}

QPushButton#quickPill:hover {
    background-color: #1a3a5c;
    border-color: #0ea5e9;
    color: #e2e8f0;
}

QPushButton#quickPill:pressed {
    background-color: #0ea5e9;
    color: #000000;
}

/* ── Anteprima immagine allegata ──────────────────────────── */
#imgPreview {
    border: 1px solid #383838;
    border-radius: 6px;
    padding: 4px 8px;
    background-color: #262626;
    color: #9ca3af;
    font-size: 11px;
}

/* ── Input multi-riga OracoloPage ─────────────────────────── */
QPlainTextEdit#chatInput {
    background-color: #2f2f2f;
    border: 1px solid #404040;
    border-radius: 10px;
    color: #e5e7eb;
    padding: 8px 14px;
    font-size: 13px;
    selection-background-color: #0ea5e9;
    selection-color: #000000;
}

QPlainTextEdit#chatInput:focus {
    border-color: #0ea5e9;
    background-color: #333333;
}

QPlainTextEdit#chatInput:hover { border-color: #4a4a4a; }

/* ── Area input row ───────────────────────────────────────── */
#inputRow {
    background-color: #111111;
    border-top: 1px solid #2a2a2a;
}

/* ── Barra azioni log (AgentiPage) ────────────────────────── */
#logActBar {
    background-color: #111111;
    border-top: 1px solid #2a2a2a;
}

/* ── Barra navigazione alternativa (modalità "Menù principale") ──── */
#navMenuBar {
    background-color: #1a1a1a;
    border-bottom: 1px solid #2a2a2a;
}

QPushButton#navMenuBtn {
    color: #a0a0a0;
    background: transparent;
    border: 1px solid transparent;
    border-radius: 5px;
    padding: 4px 10px;
    font-size: 13px;
}
QPushButton#navMenuBtn:hover {
    color: #e0e0e0;
    background-color: #2a2a2a;
}
QPushButton#navMenuBtn:checked {
    color: #00d4ff;
    background-color: #1e3a4a;
    border-color: #0ea5e9;
}

QPushButton#navMenuBackend {
    color: #a0a0a0;
    background: transparent;
    border: 1px solid #3a3a3a;
    border-radius: 5px;
    padding: 4px 10px;
    font-size: 12px;
}
QPushButton#navMenuBackend:hover {
    background-color: #2a2a2a;
    color: #e0e0e0;
}

QFrame#navMenuSep {
    color: #3a3a3a;
}
